{
  "manifest_version": 3,
  "name": "AutoLogin \u2022 Made by Faseeh",
  "version": "1.2",
  "description": "Seamlessly reconnects you to university portals automatically.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "*://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://accounts.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
